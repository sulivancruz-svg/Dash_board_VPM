# Database
DATABASE_URL="postgresql://user:password@localhost:5432/marketing_dashboard"

# Redis
REDIS_URL="redis://localhost:6379"

# Dashboard Authentication
DASHBOARD_PASSWORD="your-dashboard-password"

# Next Auth (if using authentication)
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="your-secret-key-here"

# Meta API (optional, for API calls)
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"

# Google Ads API (Conta de Serviço) — fallback permanente se Blob perder os dados
# Cole o JSON completo da service account em uma única linha
GOOGLE_ADS_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}'
